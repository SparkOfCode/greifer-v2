<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="vE2d*M,2HvUxwG*`FMaO" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="?TDXWmy$p2HF/r27%pgT"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace MakerAG {" line1="" line2="    let Position = 0" line3="    //% block" line4="    /**" line5="     * Setze den Greifer von der aktuellen auf eine neue Position" line6="     */" line7="    export function Greifer(Ziel: number) {" line8="" line9="        while (Position &lt; Ziel) {" line10="            Position += 1" line11="            calliBot2.servo(C2Servo.Servo1, Position)" line12="            basic.pause(30)" line13="        }" line14="        while (Position &gt; Ziel) {" line15="            Position += -1" line16="            calliBot2.servo(C2Servo.Servo1, Position)" line17="            basic.pause(30)" line18="        }" line19="    }" line20="}" numlines="21"></mutation></block></statement></block><block type="device_forever" id=";2@!)ZZgL/BTtbr{*JsN" x="597" y="0"></block></xml>